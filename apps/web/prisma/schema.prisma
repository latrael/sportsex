// sportsex schema.
//
// Two eras live here side by side during the 26/27 rebuild:
//   * the v1 product tables (User, Team, Player, Match, ...) — see AGENTS.md §5
//   * the v2 reference tables at the bottom of this file, written by the FPL
//     ingestion path (TODO_2627.md Phase 1).
// R2.2 is the cutover that deletes the v1 half. Nothing joins across the two.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  handle        String   @unique
  passwordHash  String?
  coinBalance   Int      @default(10000)
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime?

  holdings      Holding[]
  transactions  Transaction[]
  orders        Order[]
  comments      Comment[]
  predictions   Prediction[]
  questCompletions UserQuest[]
  friendshipsOut Friendship[] @relation("friendshipsOut")
  friendshipsIn  Friendship[] @relation("friendshipsIn")
  privateLeaderboards PrivateLeaderboard[]
  privateLbMemberships PrivateLeaderboardMember[]
}

model Team {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  shortName  String?
  league     String   @default("EPL")
  crestUrl   String?

  players    Player[]
  valuations Valuation[]
  homeMatches Match[] @relation("home")
  awayMatches Match[] @relation("away")
}

model Player {
  id           Int      @id @default(autoincrement())
  playerKey    String   @unique
  fullName     String
  teamId       Int?
  team         Team?    @relation(fields: [teamId], references: [id])
  position     String?
  posBucket    String?
  nationality  String?
  // Season-to-date stats used by pricing.ts
  appearances  Int      @default(0)
  minutes      Int      @default(0)
  goals        Int      @default(0)
  assists      Int      @default(0)
  totalShares  Int      @default(10000)
  sharesHeld   Int      @default(0)

  valuations   Valuation[]
  matchStats   PlayerMatchStat[]
  comments     Comment[]

  @@index([teamId])
  @@index([fullName])
}

model Match {
  id            Int      @id @default(autoincrement())
  externalId    String?  @unique
  homeTeamId    Int
  awayTeamId    Int
  home          Team     @relation("home", fields: [homeTeamId], references: [id])
  away          Team     @relation("away", fields: [awayTeamId], references: [id])
  kickoffAt     DateTime
  status        String   @default("scheduled") // scheduled|live|finished|settled
  homeScore     Int?
  awayScore     Int?
  settledAt     DateTime?

  playerStats   PlayerMatchStat[]
  valuations    Valuation[]
  predictions   Prediction[]

  @@index([status])
  @@index([kickoffAt])
}

model PlayerMatchStat {
  id        Int      @id @default(autoincrement())
  playerId  Int
  matchId   Int
  player    Player   @relation(fields: [playerId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id])
  minutes   Int      @default(0)
  goals     Int      @default(0)
  assists   Int      @default(0)
  // 'win' | 'draw' | 'loss' for the player's team in this match
  result    String?

  @@unique([playerId, matchId])
}

model Valuation {
  id              Int      @id @default(autoincrement())
  playerId        Int?
  teamId          Int?
  player          Player?  @relation(fields: [playerId], references: [id])
  team            Team?    @relation(fields: [teamId], references: [id])
  computedAt      DateTime @default(now())
  price           Float
  basePrice       Float?
  demandMult      Float?
  matchId         Int?
  match           Match?   @relation(fields: [matchId], references: [id])

  @@index([playerId, computedAt])
  @@index([teamId, computedAt])
}

model Holding {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  assetKind String   // 'player' | 'team'
  assetId   Int
  shares    Int
  avgCost   Float

  @@unique([userId, assetKind, assetId])
  @@index([assetKind, assetId])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  assetKind   String   // 'player' | 'team' | 'coin_grant' | 'quest_reward' | 'prediction_payout'
  assetId     Int?
  side        String   // 'buy' | 'sell' | 'credit' | 'debit'
  shares      Int      @default(0)
  price       Float    @default(0)
  coinsDelta  Int
  reason      String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([assetKind, assetId, createdAt])
}

model Order {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  assetKind    String
  assetId      Int
  side         String   // 'buy' | 'sell'
  shares       Int
  status       String   // 'pending' | 'filled' | 'cancelled'
  filledPrice  Float?
  createdAt    DateTime @default(now())
  filledAt     DateTime?

  @@index([userId, createdAt])
}

model Friendship {
  id          Int      @id @default(autoincrement())
  userId      String
  friendId    String
  status      String   // 'pending' | 'accepted'
  createdAt   DateTime @default(now())
  user        User     @relation("friendshipsOut", fields: [userId], references: [id])
  friend      User     @relation("friendshipsIn", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model PrivateLeaderboard {
  id        Int      @id @default(autoincrement())
  name      String
  joinCode  String   @unique
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  members   PrivateLeaderboardMember[]
}

model PrivateLeaderboardMember {
  id             Int      @id @default(autoincrement())
  leaderboardId  Int
  userId         String
  joinedAt       DateTime @default(now())
  leaderboard    PrivateLeaderboard @relation(fields: [leaderboardId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@unique([leaderboardId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  playerId  Int?
  teamId    Int?
  player    Player?  @relation(fields: [playerId], references: [id])
  body      String
  status    String   @default("visible") // visible|hidden|flagged
  createdAt DateTime @default(now())

  @@index([playerId, createdAt])
  @@index([teamId, createdAt])
}

model Quest {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  title        String
  body         String
  rewardCoins  Int
  repeatKind   String   // 'daily' | 'weekly' | 'one_shot'

  completions  UserQuest[]
}

model UserQuest {
  id          Int      @id @default(autoincrement())
  userId      String
  questId     Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  quest       Quest    @relation(fields: [questId], references: [id])

  @@index([userId, completedAt])
}

model Prediction {
  id           Int      @id @default(autoincrement())
  userId       String
  matchId      Int
  user         User     @relation(fields: [userId], references: [id])
  match        Match    @relation(fields: [matchId], references: [id])
  pick         String   // 'H' | 'D' | 'A'
  coinsStaked  Int
  resolved     Boolean  @default(false)
  payout       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([matchId, resolved])
}

// ---------------------------------------------------------------------------
// Schema v2 — reference tables (TODO_2627.md R1.2)
//
// Written only by the FPL ingestion path. Three things drive the shape:
//
// 1. **Identity is stable, membership is season-scoped.** FPL's `element.id`
//    and `team.id` are recycled every season — element 328 is a different
//    footballer in 25/26 than in 26/27. `element.code` / `team.code` and
//    `opta_code` are the stable identifiers, so those key the identity tables
//    (`fpl_player`, `club`) while the season-scoped ids live on the membership
//    tables (`player_season`, `club_season`). That mapping is what lets the
//    25/26 backfill be replayed after the August rollover has overwritten
//    FPL's id space (R1.5, R1.7).
// 2. **Zero name-based matching.** No lookup in this path goes through a
//    player or club name; names are payload data, never a key.
// 3. **Nullability follows the data, not the wish.** `squad_number` is null for
//    all 841 players in 25/26, `birth_date` for 19, and
//    `chance_of_playing_next_round` for 211. See R1.2's note in TODO_2627.md.

/// FPL's four element types. Mapped from `element_types[].singular_name_short`
/// at ingest rather than from the numeric id, which is FPL's to renumber.
enum Position {
  GKP
  DEF
  MID
  FWD
}

model Season {
  id        Int      @id @default(autoincrement())
  /// "2025/26"
  name      String   @unique
  /// The calendar year the season starts in: 2025 for 2025/26.
  startYear Int      @unique
  createdAt DateTime @default(now())

  clubSeasons   ClubSeason[]
  playerSeasons PlayerSeason[]
  gameweeks     Gameweek[]

  @@map("season")
}

/// A club's cross-season identity. One row per club, ever.
model Club {
  id        Int    @id @default(autoincrement())
  /// `team.code` — stable across seasons, unlike `team.id`.
  fplCode   Int    @unique
  /// Premier League `pulse_id`, kept as an independent cross-check handle.
  pulseId   Int?
  name      String
  shortName String

  seasons ClubSeason[]

  @@map("club")
}

/// A club's participation in one season: the season-scoped FPL id and the
/// strength ratings, which are re-derived each season.
model ClubSeason {
  id       Int @id @default(autoincrement())
  seasonId Int
  clubId   Int
  /// `team.id` — 1..20, alphabetical, reassigned every season.
  fplId    Int

  strength             Int
  strengthOverallHome  Int
  strengthOverallAway  Int
  strengthAttackHome   Int
  strengthAttackAway   Int
  strengthDefenceHome  Int
  strengthDefenceAway  Int

  season        Season         @relation(fields: [seasonId], references: [id])
  club          Club           @relation(fields: [clubId], references: [id])
  playerSeasons PlayerSeason[]

  @@unique([seasonId, clubId])
  @@unique([seasonId, fplId])
  @@map("club_season")
}

/// A footballer's cross-season identity. R2.2 renames this model to `Player`,
/// once the v1 `Player` above is gone and the name is free.
model FplPlayer {
  id         Int       @id @default(autoincrement())
  /// `element.code` — stable across seasons, unlike `element.id`.
  fplCode    Int       @unique
  /// `element.opta_code`, e.g. "p118748". Populated for all 841 players in
  /// 25/26 — but it is exactly "p" + `fplCode` for every one of them, so it
  /// corroborates nothing about identity that `fplCode` doesn't already say.
  /// Kept because it is the join key into Opta-derived data from other
  /// providers, which is what makes R1.6's independent cross-check possible.
  optaCode   String?   @unique
  firstName  String
  secondName String
  webName    String
  birthDate  DateTime? @db.Date

  seasons PlayerSeason[]

  @@map("fpl_player")
}

/// A footballer's registration in one season: which club, which position, and
/// the availability signals the valuation engine reads (R3.4).
model PlayerSeason {
  id           Int @id @default(autoincrement())
  seasonId     Int
  playerId     Int
  clubSeasonId Int
  /// `element.id` — season-scoped. This is the key `event/{gw}/live` uses, so
  /// (seasonId, fplId) is how R1.4 resolves a live element to a footballer.
  fplId        Int

  position Position

  /// FPL availability code: a=available, d=doubtful, i=injured, s=suspended,
  /// u=unavailable, n=not in squad.
  status                   String
  chanceOfPlayingThisRound Int?
  chanceOfPlayingNextRound Int?
  news                     String
  newsAddedAt              DateTime?

  squadNumber  Int?
  teamJoinDate DateTime? @db.Date

  /// FPL's own price, in tenths of a million. Not our price — an input.
  nowCost           Int
  selectedByPercent Decimal @db.Decimal(6, 3)

  season     Season     @relation(fields: [seasonId], references: [id])
  player     FplPlayer  @relation(fields: [playerId], references: [id])
  clubSeason ClubSeason @relation(fields: [clubSeasonId], references: [id])

  @@unique([seasonId, playerId])
  @@unique([seasonId, fplId])
  @@index([clubSeasonId])
  @@map("player_season")
}

model Gameweek {
  id       Int @id @default(autoincrement())
  seasonId Int
  /// `event.id` — 1..38 within the season.
  number   Int

  name         String
  /// Null on unscheduled events; FPL leaves it unset before a season is fixed.
  deadlineTime DateTime?
  finished     Boolean
  /// FPL's own signal that bonus points are final. R6.4 settles on this.
  dataChecked  Boolean
  isPrevious   Boolean
  isCurrent    Boolean
  isNext       Boolean

  averageEntryScore Int?
  highestScore      Int?

  season Season @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, number])
  @@map("gameweek")
}
